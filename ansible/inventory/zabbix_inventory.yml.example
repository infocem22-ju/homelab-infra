# community.zabbix.zabbix_inventory - credentials en clair (voulu)
#
# Le plugin ne supporte pas la résolution de vars Jinja2 ni Ansible Vault
# dans le contexte ansible-inventory (bug connu #713, non corrigé en 4.1.1).
# Les vars d'env ZABBIX_* sont théoriquement supportées mais non fonctionnelles.
#
# Ce fichier est exclu du repo via .gitignore.
# Pour setup : copier zabbix_inventory.yml.example et renseigner les credentials.

plugin: community.zabbix.zabbix_inventory
server_url: "http://ZABBIX_IP:PORT"
login_user: "ZABBIX_USER"
login_password: "ZABBIX_PASSWORD"
validate_certs: false

host_zapi_query:
  selectInterfaces:
    - ip
    - type
    - main

compose:
  ansible_host: zbx_interfaces[0].ip

keyed_groups:
  - key: host_groups
    prefix: ""
    separator: ""